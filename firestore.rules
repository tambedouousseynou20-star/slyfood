rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt
    //
    // Collection: businesses
    // Fields: id, ownerId, name, description, category, city, address, phone, photos, rating, reviewCount, priceRange, openingHours, deliveryAvailable, deliveryFee, subscriptionPlan, status, createdAt
    //
    // Collection: businesses/{businessId}/menu
    // Fields: id, businessId, name, description, price, photo, category, available
    //
    // Collection: orders
    // Fields: id, customerId, businessId, items, total, deliveryFee, type, status, createdAt
    //
    // Collection: reservations
    // Fields: id, customerId, businessId, date, guests, status, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "tambedouousseynou20@gmail.com" && request.auth.token.email_verified == true));
    }

    function isBusinessOwner(businessId) {
      return isAuthenticated() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'restaurant', 'admin'];
    }

    function isValidBusiness(data) {
      return data.keys().hasAll(['ownerId', 'name', 'category', 'city', 'status']) &&
             data.ownerId is string &&
             data.name is string && data.name.size() < 100 &&
             data.category in ['restaurant', 'glacier', 'cafe', 'snack'] &&
             data.city in ['Saly', 'Mbour'] &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['customerId', 'businessId', 'items', 'total', 'type', 'status']) &&
             data.customerId is string &&
             data.businessId is string &&
             data.items is list &&
             data.total is number &&
             data.type in ['pickup', 'delivery'] &&
             data.status in ['sent', 'accepted', 'preparing', 'ready', 'delivered', 'cancelled'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['customerId', 'businessId', 'rating', 'comment']) &&
             data.customerId is string &&
             data.businessId is string &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read']) &&
             data.userId is string &&
             data.title is string &&
             data.message is string &&
             data.type in ['order', 'reservation', 'system'] &&
             data.read is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
    }

    match /businesses/{businessId} {
      allow read: if true; // Publicly readable for discovery
      allow create: if isAuthenticated() && isValidBusiness(request.resource.data) && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (isBusinessOwner(businessId) || isAdmin());
      
      match /menu/{itemId} {
        allow read: if true;
        allow write: if isBusinessOwner(businessId) || isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.customerId == request.auth.uid;
        allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isAdmin());
      }
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isBusinessOwner(resource.data.businessId) || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isBusinessOwner(resource.data.businessId) || isAdmin());
    }

    match /reservations/{resId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isBusinessOwner(resource.data.businessId) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.customerId || isBusinessOwner(resource.data.businessId) || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated(); // Allow system or other users to notify (e.g. restaurant notifying customer)
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
